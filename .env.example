# PostgreSQL / Supabase — connection string (pooling or direct)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# OpenAI API (coach IA, corrections, plans)
OPENAI_API_KEY="sk-..."
